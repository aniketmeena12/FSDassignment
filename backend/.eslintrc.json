{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": ["airbnb-base"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": ["warn", { "allow": ["log", "warn", "error"] }],
    "no-unused-vars": [
      "error",
      { "argsIgnorePattern": "^_", "destructuredArrayIgnorePattern": "^_" }
    ],
    "consistent-return": "warn",
    "no-param-reassign": [
      "error",
      {
        "props": true,
        "ignorePropertyModificationsFor": ["err", "req", "res", "error"]
      }
    ],
    "import/no-extraneous-dependencies": [
      "error",
      { "devDependencies": ["tests/**", "**/*.test.js", "**/*.spec.js"] }
    ]
  }
}
